{
  "name": "compilerfish-react",
  "version": "0.0.0",
  "description": "Compilerfish React bindings — provider, FAB, useFeedback hook. Drop-in for any React app.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:cover": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "homepage": "https://github.com/tatlacas-com/compilerfish-sdk-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tatlacas-com/compilerfish-sdk-js.git",
    "directory": "packages/react"
  },
  "keywords": [
    "compilerfish",
    "react",
    "qa",
    "feedback",
    "bug-report"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "compilerfish-sdk": "workspace:*",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "compilerfish-sdk": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
